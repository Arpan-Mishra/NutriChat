# NutriChat Backend Environment Variables

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/nutrichat

# JWT Auth
JWT_SECRET_KEY=generate-a-random-32-byte-hex-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6

# USDA FoodData Central (free key from https://api.data.gov)
USDA_API_KEY=

# Edamam Food Database (free tier from https://developer.edamam.com)
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Twilio (SMS/WhatsApp OTP delivery — leave empty for debug mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App
DEBUG=true
